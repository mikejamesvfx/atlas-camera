__pycache__/
*.py[cod]
*$py.class

.pytest_cache/
.pytest_tmp/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

.venv/
venv/
.env
node_modules/
ui/node_modules/
ui/dist/

.serena/
.claude/
.agents/

test_scenes/
validation_output/
review_packages/
migration_artifacts/
external_datasets/
local_datasets/
atlas_ui_projects/
atlas_camera.egg-info/
atlas_exports/
examples/review_packages/*
!examples/review_packages/.gitkeep

*.exr
*.abc
*.fbx
*.usdc
*.blend
*.ma
*.mb

# Model weights / checkpoints — never commit these to a ComfyUI node repo
*.safetensors
*.ckpt
*.pth
*.onnx
*.gguf

# Large or generated images should stay out of git. Small hand-written fixtures
# in tests/fixtures are allowed.
*.png
*.jpg
*.jpeg
*.tif
*.tiff
!tests/fixtures/*
# Brand/registry assets are hand-authored and must ship (the registry Icon URL
# points at assets/atlas_camera_icon.png).
!assets/*.png
!examples/images/.gitkeep

# Session/tooling artifacts
.playwright-mcp/
.pytest_tmp_atlas_output_desk*/

# Personal documents — never publish
docs/applications/

# Doc-embedded scene thumbnails are the exception to the *.jpg ban
!docs/images/*.jpg
!docs/images/*.svg

# Python packaging artifacts (pip wheel / python -m build)
dist/
build/
*.egg-info/

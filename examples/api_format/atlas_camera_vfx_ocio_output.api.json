{
  "1": {"class_type": "LoadImage", "inputs": {"image": "example.png"}},
  "2": {"class_type": "AtlasLearnedSolveFromImage", "inputs": {
    "image": ["1", 0], "height_mode": "measure_from_depth", "camera_height_m": 1.6,
    "depth_model": "depth-anything/Depth-Anything-V2-Metric-Outdoor-Large-hf",
    "sensor_width_mm": 36, "weights": "pinhole", "device": "auto"}},
  "3": {"class_type": "AtlasDeriveProjectionGeometry", "inputs": {
    "solve": ["2", 0], "image": ["1", 0],
    "depth_model": "depth-anything/Depth-Anything-V2-Metric-Outdoor-Large-hf",
    "max_walls": 4, "max_objects": 3, "device": "auto", "geometry_mode": "relief_mesh",
    "relief_grid": 96, "primitive_method": "azimuth_walls", "scene_type": "manual"}},
  "4": {"class_type": "AtlasExportReliefMesh", "inputs": {
    "solve": ["3", 0], "image": ["1", 0], "output_dir": "atlas_exports/vfx_ocio_demo",
    "grid_long_edge": 128, "depth_edge_rel": 0.5,
    "depth_model": "depth-anything/Depth-Anything-V2-Metric-Outdoor-Large-hf",
    "device": "auto", "format": "both"}},
  "5": {"class_type": "OCIOWrite", "inputs": {
    "images": ["1", 0], "from_colorspace": "sRGB - Display", "output_colorspace": "ACEScg",
    "container": "still image", "still_format": "exr", "video_codec": "prores_4444",
    "bit_depth": "16f", "auto_range": false, "first_frame": 1, "last_frame": 0,
    "start_number": 1, "source_start": 1, "raw_data": false,
    "output_folder": "atlas_exports/vfx_ocio_demo", "filename": "atlas_source_plate",
    "colorspace_in_name": true, "auto_colorspace": true, "compression": "zip"}}
}
